{
	"name": "take-shelter-now",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --exit-zero-on-changes",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest --project=client --project=server",
		"test:unit:coverage": "vitest run --coverage --project=client --project=server --coverage.reportsDirectory=coverage/unit",
		"test:storybook:coverage": "vitest run --coverage --project=storybook --coverage.reportsDirectory=coverage/storybook",
		"test:storybook": "vitest --project=storybook",
		"test": "npm run test:unit -- --run && npm run test:storybook -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"shadcn": "shadcn-svelte",
		"fetch-shelters": "tsx static/fetch-shelters.ts"
	},
	"dependencies": {
		"leaflet": "^1.9.4"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-a11y": "^10.2.16",
		"@storybook/addon-vitest": "^10.2.16",
		"@storybook/addon-svelte-csf": "^5.0.11",
		"@storybook/sveltekit": "^10.2.16",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.3.5",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/browser": "^4.0.18",
		"@vitest/browser-playwright": "^4.0.18",
		"chromatic": "^15.2.0",
		"clsx": "^2.1.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"jsdom": "^28.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.1.1",
		"storybook": "^10.2.14",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.0",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.6"
	}
}
