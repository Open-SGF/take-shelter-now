{
	"name": "take-shelter-now",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --exit-zero-on-changes",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest --project=unit",
		"test:unit:coverage": "vitest run --coverage --project=unit --coverage.reportsDirectory=coverage/unit",
		"test:storybook:coverage": "vitest run --coverage --project=storybook --coverage.reportsDirectory=coverage/storybook",
		"test:storybook": "vitest --project=storybook",
		"test": "npm run test:unit -- --run && npm run test:storybook -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"shadcn": "shadcn-svelte"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.1",
		"@maplibre/maplibre-gl-leaflet": "^0.1.3",
		"@stadiamaps/api": "^9.1.0",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"csv-parse": "^6.2.1",
		"leaflet": "^1.9.4",
		"maplibre-gl": "^5.24.0",
		"sitemap": "^9.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^1.14.0",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.3.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.6",
		"@storybook/sveltekit": "^10.3.6",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.6.0",
		"@types/vt-pbf": "^3.1.1",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18",
		"chromatic": "^16.6.3",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"mode-watcher": "^1.1.0",
		"msw": "2.14.2",
		"msw-storybook-addon": "^2.0.7",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.2.7",
		"storybook": "^10.2.14",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"svelte-sonner": "^1.1.1",
		"tailwindcss": "^4.0.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "8.0.10",
		"vitest": "^4.0.6",
		"vt-pbf": "^3.1.3"
	},
	"msw": {
		"workerDirectory": [
			".storybook/public"
		]
	}
}
